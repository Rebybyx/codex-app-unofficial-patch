+    throw new Error(`Expected exactly one native avatar overlay page bundle, found ${matches.length}: ${matches.join(", ")}`);
+  }
+
+  return matches[0];
+}
+
+/**
+ * 2026-06-11 苍朮
+ * Purpose: find the shared app CSS bundle that paints the Electron root background behind the avatar overlay.
+ * @param {string} assetsRoot - Extracted webview/assets directory to scan.
+ * @returns {Promise<string>} Absolute path to the only matching shared app CSS bundle.
+ */
+async function findAppRootCssBundle(assetsRoot) {
+  const candidates = (await listFiles(assetsRoot)).filter((filePath) => /^app(?:--)?-[A-Za-z0-9_-]+\.css$/.test(basename(filePath)));
+  const matches = candidates.filter((filePath) => {
+    const source = readFileSync(filePath, "utf8");
+    return (
+      source.includes(APP_ROOT_BACKGROUND_CSS_ANCHOR) &&
+      (source.includes(AVATAR_OVERLAY_CONTENT_FRAME_SELECTOR) || source.includes(".bg-transparent{background-color:#0000}"))
+    );
+  });
+
+  if (matches.length !== 1) {
+    throw new Error(`Expected exactly one app root CSS bundle, found ${matches.length}: ${matches.join(", ")}`);
+  }
+
+  return matches[0];
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: verify the avatar notification priority and transient animation precedence anchors across webview bundles.
+ * @param {string} assetsRoot - Extracted webview/assets directory to scan.
+ * @returns {Promise<void>} Resolves when all priority-related anchors are present.
+ */
+async function validateAvatarPriorityAnchors(assetsRoot) {
+  const sources = (await listFiles(assetsRoot))
+    .filter((filePath) => filePath.endsWith(".js"))
+    .map((filePath) => readFileSync(filePath, "utf8"))
+    .join("\n");
+  assertAnchorGroupsPresent(
+    sources,
+    [
+      { description: "notification priority", anchors: [NOTIFICATION_PRIORITY_ANCHOR] },
+      { description: "hover transient priority", anchors: [TRANSIENT_HOVER_PRIORITY_ANCHOR] },
+      { description: "drag transient priority", anchors: [TRANSIENT_DRAG_PRIORITY_ANCHOR, TRANSIENT_DRAG_PRIORITY_ANCHOR_26_609] },
+      { description: "transient state prop", anchors: [TRANSIENT_STATE_PROP_ANCHOR, TRANSIENT_STATE_PROP_ANCHOR_26_609] },
+    ],
+    "avatar notification priority and transient animation precedence",
+  );
+}
+
+/**
+ * 2026-06-11 苍朮
+ * Purpose: patch the Linux avatar overlay window-tray visibility store into the main bundle.
+ * @param {string} source - Electron main-process bundle source to patch.
+ * @returns {{source: string, changed: boolean, oldCount: number, newCount: number}} Patched source and post-patch store counts.
+ */
+function patchTrayVisibilityStore(source) {
+  return replaceExactPolicy(source, TRAY_VISIBILITY_STORE_ANCHOR, TRAY_VISIBILITY_STORE_POLICY, "avatar tray visibility store");
+}
+
+/**
+ * 2026-06-11 苍朮
+ * Purpose: insert the Linux-only BrowserWindow shape synchronization hook into the main bundle.
+ * @param {string} source - Electron main-process bundle source to patch.
+ * @returns {{source: string, changed: boolean, oldCount: number, newCount: number}} Patched source and post-patch shape hook counts.
+ */
+function patchWindowShapeSync(source) {
+  const shapeCallResult = replaceExactPolicy(source, WINDOW_SHAPE_SYNC_ANCHOR, WINDOW_SHAPE_SYNC_POLICY, "avatar Linux window shape sync call");
+  source = shapeCallResult.source;
+
+  const methodResult = replaceExactPolicyPairFromAny(
+    source,
+    [
+      [WINDOW_SHAPE_METHOD_ANCHOR, WINDOW_SHAPE_METHOD_POLICY],
+      [WINDOW_SHAPE_METHOD_LEGACY_POLICY, WINDOW_SHAPE_METHOD_POLICY],
+      [WINDOW_SHAPE_METHOD_ANCHOR_26_609, WINDOW_SHAPE_METHOD_POLICY_26_609],
+    ],
+    "avatar Linux window shape sync method",
+  );
+  source = methodResult.source;
+
+  const initResult = replaceExactPolicy(source, WINDOW_SHAPE_INIT_ANCHOR, WINDOW_SHAPE_INIT_POLICY, "avatar Linux window shape initialization");
+  source = initResult.source;
+
+  const resetResult = replaceExactPolicy(source, WINDOW_SHAPE_RESET_ANCHOR, WINDOW_SHAPE_RESET_POLICY, "avatar Linux window shape reset");
+
+  return {
+    source: resetResult.source,
+    changed: shapeCallResult.changed || methodResult.changed || initResult.changed || resetResult.changed,
+    oldCount: countOccurrences(resetResult.source, WINDOW_SHAPE_SYNC_ANCHOR),
+    newCount: countOccurrences(resetResult.source, WINDOW_SHAPE_SYNC_POLICY),
+  };
+}
+
+/**
+ * 2026-06-11 苍朮
+ * Purpose: send explicit tray visibility from the native avatar overlay renderer so Linux shape follows visible prompt bubbles.
+ * @param {string} bundlePath - Absolute path to the webview native avatar overlay page JavaScript bundle.
+ * @returns {{bundlePath: string, hash: string, changed: boolean, oldCount: number, newCount: number}} Patched bundle path, SHA256 hash, whether content changed, and post-patch message counts.
+ */
+function patchAvatarOverlayNativePageBundle(bundlePath) {
+  const source = readFileSync(bundlePath, "utf8");
+  const result = replaceExactPolicyPairFromAny(
+    source,
+    [
+      [NATIVE_PAGE_SIZE_MESSAGE_ANCHOR, NATIVE_PAGE_SIZE_MESSAGE_POLICY],
+      [NATIVE_PAGE_SIZE_MESSAGE_ANCHOR_26_609, NATIVE_PAGE_SIZE_MESSAGE_POLICY_26_609],
+    ],
+    "native avatar overlay tray visibility message",
+  );
+
+  writeFileSync(bundlePath, result.source);
+  return {
+    bundlePath,
+    changed: result.changed,
+    hash: createHash("sha256").update(result.source).digest("hex"),
+    oldCount: result.oldCount,
+    newCount: result.newCount,
+  };
+}
+
+/**
+ * 2026-06-11 苍朮
+ * Purpose: make the avatar overlay page root transparent so Linux window alpha reaches the desktop instead of the themed app background.
+ * @param {string} bundlePath - Absolute path to the shared app CSS bundle.
+ * @returns {{bundlePath: string, hash: string, changed: boolean, rootBackgroundAnchorCount: number, transparentRootPolicyCount: number}} Patched CSS path, SHA256 hash, whether content changed, and post-patch root-background counts.
+ */
+function patchAvatarOverlayRootTransparencyCss(bundlePath) {
+  let source = readFileSync(bundlePath, "utf8");
+  const rootBackgroundAnchorCount = countOccurrences(source, APP_ROOT_BACKGROUND_CSS_ANCHOR);
+  let transparentRootPolicyCount = countOccurrences(source, AVATAR_OVERLAY_TRANSPARENT_ROOT_CSS);
+  let changed = false;
+
+  if (rootBackgroundAnchorCount !== 1) {
+    throw new Error(`Expected one app root background CSS anchor, found ${rootBackgroundAnchorCount}`);
+  }
+
+  if (transparentRootPolicyCount === 0) {
+    source = `${source}\n${AVATAR_OVERLAY_TRANSPARENT_ROOT_CSS}`;
+    transparentRootPolicyCount = countOccurrences(source, AVATAR_OVERLAY_TRANSPARENT_ROOT_CSS);
+    changed = true;
+  } else if (transparentRootPolicyCount !== 1) {
+    throw new Error(`Expected zero or one avatar overlay transparent root CSS policy, found ${transparentRootPolicyCount}`);
+  }
+
+  writeFileSync(bundlePath, source);
+  return {
+    bundlePath,
+    changed,
+    hash: createHash("sha256").update(source).digest("hex"),
+    rootBackgroundAnchorCount,
+    transparentRootPolicyCount,
+  };
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: replace the avatar overlay passthrough, Linux transparent-window startup policies, and Linux window-shape sync.
+ * @param {string} bundlePath - Absolute path to the Electron main-process JavaScript bundle.
+ * @returns {{bundlePath: string, hash: string, changed: boolean, pointerOldCount: number, pointerNewCount: number, transparentOldCount: number, transparentNewCount: number, trayVisibilityOldCount: number, trayVisibilityNewCount: number, windowShapeOldCount: number, windowShapeNewCount: number}} Patched bundle path, SHA256 hash, whether content changed, and post-patch policy counts.
+ */
+function patchAvatarOverlayBundle(bundlePath) {
+  let source = readFileSync(bundlePath, "utf8");
+  const pointerResult = replaceExactPolicy(source, POINTER_INTERACTIVITY_ANCHOR, LINUX_POINTER_INTERACTIVITY_POLICY, "avatar pointer policy");
+  source = pointerResult.source;
+
+  const transparentOldCount = countUnpatchedTransparentVisualsAnchors(source);
+  const transparentNewCount = countOccurrences(source, LINUX_TRANSPARENT_VISUALS_POLICY);
+  let transparentChanged = false;
+
+  if (transparentOldCount === 1 && transparentNewCount === 0) {
+    source = source.replace(APP_READY_ANCHOR, LINUX_TRANSPARENT_VISUALS_POLICY);
+    transparentChanged = true;
+  } else if (transparentOldCount !== 0 || transparentNewCount !== 1) {
+    throw new Error(
+      `Expected old=1/new=0 or old=0/new=1 for Linux transparent visuals, found old=${transparentOldCount}, new=${transparentNewCount}`,
+    );
+  }
+
+  const trayVisibilityResult = patchTrayVisibilityStore(source);
+  source = trayVisibilityResult.source;
+
+  const windowShapeResult = patchWindowShapeSync(source);
+  source = windowShapeResult.source;
+
+  assertAnchorsPresent(source, DYNAMIC_LAYOUT_ANCHORS, "avatar dynamic layout");
+
+  writeFileSync(bundlePath, source);
+  return {
+    bundlePath,
+    changed: pointerResult.changed || transparentChanged || trayVisibilityResult.changed || windowShapeResult.changed,
+    hash: createHash("sha256").update(source).digest("hex"),
+    pointerOldCount: countOccurrences(source, POINTER_INTERACTIVITY_ANCHOR),
+    pointerNewCount: countOccurrences(source, LINUX_POINTER_INTERACTIVITY_POLICY),
+    transparentOldCount: countUnpatchedTransparentVisualsAnchors(source),
+    transparentNewCount: countOccurrences(source, LINUX_TRANSPARENT_VISUALS_POLICY),
+    trayVisibilityOldCount: countOccurrences(source, TRAY_VISIBILITY_STORE_ANCHOR),
+    trayVisibilityNewCount: countOccurrences(source, TRAY_VISIBILITY_STORE_POLICY),
+    windowShapeOldCount: countOccurrences(source, WINDOW_SHAPE_SYNC_ANCHOR),
+    windowShapeNewCount: countOccurrences(source, WINDOW_SHAPE_SYNC_POLICY),
+  };
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: keep non-idle avatar animation frames looping while the owning session state remains active.
+ * @param {string} bundlePath - Absolute path to the webview codex-avatar JavaScript bundle.
+ * @returns {{bundlePath: string, hash: string, changed: boolean, oldCount: number, newCount: number}} Patched bundle path, SHA256 hash, whether content changed, and post-patch animation counts.
+ */
+function patchCodexAvatarBundle(bundlePath) {
+  const source = readFileSync(bundlePath, "utf8");
+  const result = replaceExactPolicy(
+    source,
+    TEMPORARY_STATE_ANIMATION_ANCHOR,
+    PERSISTENT_STATE_ANIMATION_POLICY,
+    "codex-avatar persistent state animation",
+  );
+
+  writeFileSync(bundlePath, result.source);
+  return {
+    bundlePath,
+    changed: result.changed,
+    hash: createHash("sha256").update(result.source).digest("hex"),
+    oldCount: result.oldCount,
+    newCount: result.newCount,
+  };
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: run the system asar CLI with inherited stdio so pack/extract failures surface directly.
+ * @param {string} command - Asar subcommand to execute.
+ * @param {string[]} args - Arguments passed to the asar CLI after the subcommand.
+ * @returns {void}
+ */
+function runAsar(command, args) {
+  execFileSync(ASAR_BIN, [command, ...args], { stdio: "inherit" });
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: replace the original archive with the patched archive after repacking.
+ * @param {string} originalAsar - Path to the original app.asar archive.
+ * @param {string} patchedAsar - Path to the newly packed app.asar archive.
+ * @returns {void}
+ */
+function replacePackedArchive(originalAsar, patchedAsar) {
+  renameSync(patchedAsar, originalAsar);
+}
+
+/**
+ * 2026-06-10 苍朮
+ * Purpose: extract, patch, validate, and repack Codex's app.asar while preserving native module unpacking.
+ * @param {string | undefined} appAsar - Path to the app.asar archive inside the extracted Linux bundle.
+ * @returns {Promise<void>} Resolves after the archive has been replaced with the patched version.
+ */
+async function main(appAsar) {
+  if (!appAsar || !existsSync(appAsar)) {
+    throw new Error(`app.asar not found: ${appAsar ?? "<missing argument>"}`);
+  }
+
+  const tempRoot = mkdtempSync(join(dirname(appAsar), ".codex-app-unofficial-avatar-asar-"));
+  const extractedRoot = join(tempRoot, "app");
+  const patchedAsar = join(tempRoot, "app.asar");
+
+  try {
+    runAsar("extract", [appAsar, extractedRoot]);
+    const buildRoot = join(extractedRoot, ".vite", "build");
+    const assetsRoot = join(extractedRoot, "webview", "assets");
+    const mainResult = patchAvatarOverlayBundle(await findAvatarOverlayBundle(buildRoot));
+    const nativePageResult = patchAvatarOverlayNativePageBundle(await findAvatarOverlayNativePageBundle(assetsRoot));
+    const rootCssResult = patchAvatarOverlayRootTransparencyCss(await findAppRootCssBundle(assetsRoot));
+    const avatarResult = patchCodexAvatarBundle(await findCodexAvatarBundle(assetsRoot));
+    await validateAvatarPriorityAnchors(assetsRoot);
+
+    runAsar("pack", [extractedRoot, patchedAsar, "--unpack-dir", UNPACK_DIRS]);
+    replacePackedArchive(appAsar, patchedAsar);
+
+    console.log(`${mainResult.changed ? "Patched" : "Already patched"} ${mainResult.bundlePath}`);
+    console.log(`Avatar pointer policy old=${mainResult.pointerOldCount}/new=${mainResult.pointerNewCount}`);
+    console.log(`Transparent visuals old=${mainResult.transparentOldCount}/new=${mainResult.transparentNewCount}`);
+    console.log(`Avatar tray visibility store old=${mainResult.trayVisibilityOldCount}/new=${mainResult.trayVisibilityNewCount}`);
+    console.log(`Avatar Linux window shape old=${mainResult.windowShapeOldCount}/new=${mainResult.windowShapeNewCount}`);
+    console.log(`Avatar overlay bundle sha256=${mainResult.hash}`);
+    console.log(`${nativePageResult.changed ? "Patched" : "Already patched"} ${nativePageResult.bundlePath}`);
+    console.log(`Native avatar tray visibility message old=${nativePageResult.oldCount}/new=${nativePageResult.newCount}`);
+    console.log(`Native avatar overlay page bundle sha256=${nativePageResult.hash}`);
+    console.log(`${rootCssResult.changed ? "Patched" : "Already patched"} ${rootCssResult.bundlePath}`);
+    console.log(
+      `Avatar overlay transparent root CSS root-anchor=${rootCssResult.rootBackgroundAnchorCount}/policy=${rootCssResult.transparentRootPolicyCount}`,
+    );
+    console.log(`Avatar overlay transparent root CSS bundle sha256=${rootCssResult.hash}`);
+    console.log(`${avatarResult.changed ? "Patched" : "Already patched"} ${avatarResult.bundlePath}`);
+    console.log(`Codex avatar persistent animation old=${avatarResult.oldCount}/new=${avatarResult.newCount}`);
+    console.log(`Codex avatar bundle sha256=${avatarResult.hash}`);
+    console.log("Avatar dynamic layout and priority anchors verified");
+  } finally {
+    rmSync(tempRoot, { recursive: true, force: true });
+  }
+}
+
+main(process.argv[2]).catch((error) => {
+  console.error(error);
+  process.exit(1);
+});
